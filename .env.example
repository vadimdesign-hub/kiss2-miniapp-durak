# --- Backend (packages/backend/.env) ---

# Server

API_PORT=3001
APP_ENV=stage
LOG_LEVEL=info
NODE_ENV=development
SERVICE_NAME=durak

# Sentry (optional — leave empty to disable)
SENTRY_DSN=

# Global backend (platform services base URL, each service is prefixed: /wallet, /user, etc.)
GLOBAL_BACKEND_BASE_URL=https://api-stage.kisskissplay.com

# Auth secret key (set when running with proper value for stage/prod from global backend)
AUTH_SECRET_KEY=your-secret-key-here

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kiss2_miniapp_vadim_playground?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Redpanda / Kafka
KAFKA_SEED_BROKERS=localhost:19092
KAFKA_USERNAME=
KAFKA_PASSWORD=

WALLET_API_URL=https://api-stage.kisskissplay.com/wallet

# --- Frontend (packages/frontend/.env) ---

VITE_API_BASE_URL=http://localhost:3001
VITE_GLOBAL_BACKEND_BASE_URL=https://api-stage.kisskissplay.com
VITE_APP_ENV=stage
VITE_SERVICE_NAME=durak
VITE_SENTRY_DSN=
